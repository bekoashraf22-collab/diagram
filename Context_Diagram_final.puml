@startuml Context_Diagram

scale 2

skinparam nodesep 180
skinparam ranksep 130
skinparam defaultTextAlignment center

skinparam rectangle {
  BorderColor #CC0000
  FontColor #000000
  FontSize 13
  FontStyle Bold
  BorderThickness 2
  BackgroundColor #F9F9F9
  RoundCorner 0
  Padding 14
}

skinparam card {
  BackgroundColor #FFE5E5
  BorderColor #CC0000
  BorderThickness 2
  FontSize 12
  FontColor #000000
  Padding 16
}

skinparam arrow {
  Color #CC0000
  FontColor #333333
  FontSize 11
}

title <size:15><b>Context Diagram</b></size>\nBlood Rescue Platform

rectangle "Donor" as DONOR
card "**0**\n==\nBlood Rescue\nPlatform" as SYS
rectangle "Hospital" as HOSP
rectangle "Admin" as ADMIN

' Horizontal arrows - \n\n pushes label away from line
DONOR -right-> SYS : Registration data\n\n
SYS -left-> DONOR : \n\nNotifications & history

SYS -right-> HOSP : Matched donors\n\n
HOSP -left-> SYS : \n\nBlood requests

' Vertical arrows - spaces push label left or right
ADMIN -down-> SYS : "        Admin actions"
SYS -up-> ADMIN : "Platform statistics        "

@enduml
